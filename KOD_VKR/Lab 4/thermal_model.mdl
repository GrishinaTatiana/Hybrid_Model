SAVEPER = 1
    ~
    ~
    |

Room Temperature = INTEG ( (Heat Gain from People - Heat Loss) / Air Heat Capacity, Initial Temperature)
    ~ Degree C
    ~

    |

Heat Gain from People = people_count * Heat per Person
    ~ Watt
    ~
    |

Heat Loss = (Room Temperature - Outside Temperature) * Insulation Factor
    ~ Watt
    ~

    |

people_count = 0
    ~ person
    ~
    |

Heat per Person = 80
    ~ Watt/person
    ~ теплоотдача человека, норма 100

    |

Air Heat Capacity = 50000
    ~ Joule/Degree C
    ~ чем меньше это число, тем меньше энергии нужно, чтобы поднять температуру на 1 градус
    |

Outside Temperature = 20
    ~ Degree C
    ~ уличная температура

    |

Insulation Factor = 20
    ~ Watt/Degree C
    ~ скорость остывания помещения, норма 15-20
    |

Initial Temperature = 22
    ~ Degree C
    ~
    |

AC_POWER = 0
    ~ Watt
    ~ мощность кондиционера (0 - выключен, 500 - включен)
    |